{
  "compilerOptions": {
      "target": "es2024",
      "module": "node20",
      "noEmitOnError": true,
      "rootDir": "./src",
      "outDir": "./lib",
      "sourceMap": false,
      "declaration": false,
      "removeComments": true,
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": false,
      "noFallthroughCasesInSwitch": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "types": ["node"]
  },
  "compileOnSave": true
}
